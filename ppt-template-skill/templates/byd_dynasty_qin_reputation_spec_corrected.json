    "content_style": {
      "slide_file": "slide3.xml",
      "placeholders": {
        "page_title": "文本框 18"
      },
      "has_background_image": false,
      "_note": "内容页顶部有标题文本，正文区由 style_clone 绘制。"
    },
    "end": {
      "slide_file": "slide4.xml",
      "placeholders": {},
      "has_background_image": true,
      "_note": "结束页主要为居中图片元素，无文字占位。"
    }
  }
